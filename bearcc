#!/bin/bash

set -e  # Stop on first error

echo "Finding all .c files..."
c_files=$(find . -name '*.c')

if [ -z "$c_files" ]; then
  echo "No C files found."
  exit 1
fi

# Create a temporary script for Bear to run
echo "Generating build script for Bear..."

build_temp=./.build_with_flags.sh
echo '#!/bin/bash' > "$build_temp"
echo 'set -e' >> "$build_temp"

for file in $c_files; do
  echo "gcc -std=c11 -pedantic -Wall -Wextra -Wshadow -Wconversion \
-funsigned-char -fsanitize=undefined,address,leak \
-fno-sanitize-recover=signed-integer-overflow -fno-omit-frame-pointer \
-g -O -c \"$file\" -o \"${file%.*}.o\"" >> "$build_temp"
done

chmod +x "$build_temp"

echo "Running Bear with generated script..."
bear -- "$build_temp"

echo "Done. compile_commands.json created."

# Optional: clean up
rm "$build_temp"
